# Frontend Environment Variables
# Copy this to .env.local and fill in your actual values

# API Configuration
REACT_APP_BASE_URL=http://localhost:4000/api/v1

# For Production in Vercel, update to:
# REACT_APP_BASE_URL=https://your-backend-domain.com/api/v1

# Google OAuth (Required for Google Sign-in)
REACT_APP_GOOGLE_CLIENT_ID=your_google_client_id_here

# Payment Integration
RAZORPAY_KEY=your_razorpay_test_key_here

# Note: Chatbot API keys are now handled by backend only (Groq API)
